# =============================================================================
#  AI Voice Assistant — Environment Variables
# =============================================================================
# Copy this file to `.env.local` and fill in at least ONE provider key.
#   cp .env.example .env.local   (macOS / Linux)
#   copy .env.example .env.local (Windows)
#
# All providers below have a FREE tier. You only need a key for the provider
# you select via AI_PROVIDER (users can also switch providers in Settings,
# but a matching key must exist on the server for that provider to work).
# =============================================================================

# Which provider to use by default: groq | gemini | openrouter
AI_PROVIDER=groq

# --- Groq (recommended, very fast, free) -------------------------------------
# Get a free key: https://console.groq.com/keys
GROQ_API_KEY=

# --- Google Gemini (free tier) -----------------------------------------------
# Get a free key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- OpenRouter (free models) ------------------------------------------------
# Get a free key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# =============================================================================
#  Optional: override the default model for each provider.
#  Leave commented to use the sensible free defaults baked into the code.
# =============================================================================
# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_MODEL=gemini-1.5-flash
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
